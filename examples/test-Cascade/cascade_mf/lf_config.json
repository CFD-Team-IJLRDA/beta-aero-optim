{
    "study": {
        "study_type": "cascade",
        "ffd_type": "ffd_pod_2d",
        "file": "../data/lrn_cascade.dat",
        "outdir": "@outdir",
        "custom_file": "custom_cascade.py"
    },
    "optim": {
        "n_design": @n_design,
        "doe_size": @doe_size,
        "max_generations": 1,
        "bound": [-0.2, 0.2],
        "QoI": "LossCoef",
        "custom_doe": "@custom_doe",
        "constraint": false,
        "budget": 20,
        "nproc_per_sim": 5
    },
    "ffd": {
        "pod_ncontrol": 2,
        "ffd_dataset_size": 1000
    },
    "gmsh": {
        "mesh": {
            "bl": false,
            "nodes_inlet": 20,
            "nodes_outlet": 20,
            "side_nodes_inlet": 20,
            "side_nodes_outlet": 50,
            "curved_side_nodes": 10,
            "le": 32,
            "te": 32,
            "nodes_ss": 50,
            "nodes_ps": 50,
            "structured": false
        },
        "view": {
            "GUI": true,
            "quality": false,
            "nview": 1
        }
    },
    "simulator": {
        "ref_input": "../cascade_base/cascade_base.wolf",
        "post_process": {
            "residual.dat": ["ResTot"],
            "turbocoef.dat": ["LossCoef"]
        },
        "exec_cmd": "python3 /home/mciarlatani/GPROptimization/aero-optim/examples/LRN-CASCADE/cascade_base/execute.py -in @.mesh -nproc 96 -ms 3"
    }
}
